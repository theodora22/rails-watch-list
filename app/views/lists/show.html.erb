<div class="container mt-4">
  <h1><%= @list.name %></h1>
  <%= link_to "Add a Movie", new_list_bookmark_path(@list), class: "btn btn-primary mb-3" %>

  <% @list.bookmarks.each do |bookmark| %>
    <div class="card mb-3">
      <div class="card-body d-flex justify-content-between align-items-start">
        <div>
          <h5 class="card-title"><%= bookmark.movie.title %></h5>
          <p class="card-text"><%= bookmark.comment %></p>
        </div>
        <%= link_to "Remove", bookmark_path(bookmark), data: { turbo_method: :delete }, class: "btn btn-danger btn-sm" %>
      </div>
    </div>
  <% end %>
</div>
